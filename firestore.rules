rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // A user owns their private profile doc (email, roles, etc.).
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Public profile (name, headline, bio, photo): anyone can read; owner writes.
    match /profiles/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // "List your land" applications: anyone may submit; nobody reads them
    // from the client (reviewed in the console / admin tooling).
    match /hostApplications/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // "Request to join" from signed-out visitors: submit-only, same as above.
    match /courseRequests/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Founding-member reservations and the waitlist: anyone may submit;
    // not readable from the client (reviewed via admin tooling).
    match /foundingReservations/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }
    match /waitlist/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    // Designed residencies are private to the user who saved them.
    match /residencies/{id} {
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow read, update, delete: if request.auth != null
                    && request.auth.uid == resource.data.uid;
    }

    // Host-posted project needs: public to read; only the author can write.
    match /hostNeeds/{id} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null
                    && request.auth.uid == resource.data.uid;
    }

    // Published listings are public to read; only the owner can write.
    match /listings/{id} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow update, delete: if request.auth != null
                    && request.auth.uid == resource.data.uid;

      // Interest registrations ("gauge demand"). A signed-in student writes
      // their own signup (doc id is their uid). The listing's owner may read
      // every signup to see demand; the signer can read or withdraw their own.
      match /signups/{uid} {
        allow create: if request.auth != null && request.auth.uid == uid;
        allow read: if request.auth != null
                    && (request.auth.uid == uid
                        || get(/databases/$(database)/documents/listings/$(id)).data.uid == request.auth.uid);
        allow delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Course reservations are private to the user who made them.
    match /enrollments/{id} {
      allow create, update: if request.auth != null
                    && request.auth.uid == request.resource.data.uid;
      allow read, delete: if request.auth != null
                    && request.auth.uid == resource.data.uid;
    }

    // Two-way messaging: a conversation is private to its two participants.
    match /conversations/{id} {
      allow read: if request.auth != null
                  && request.auth.uid in resource.data.participants;
      allow create: if request.auth != null
                  && request.auth.uid in request.resource.data.participants;
      // Participants may update activity/read fields, but not change who's in it.
      allow update: if request.auth != null
                  && request.auth.uid in resource.data.participants
                  && request.resource.data.participants == resource.data.participants;

      match /messages/{mid} {
        allow read: if request.auth != null
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(id)).data.participants;
        allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.senderUid
                    && request.auth.uid in get(/databases/$(database)/documents/conversations/$(id)).data.participants;
      }
    }
  }
}
